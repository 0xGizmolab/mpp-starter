#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/mppx@0.4.8_@modelcontextprotocol+sdk@1.27.1_zod@4.3.6__express@5.2.1_hono@4.12.8_openap_a27fbefda71f01d718c4a26ef87624a2/node_modules/mppx/src/node_modules:/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/mppx@0.4.8_@modelcontextprotocol+sdk@1.27.1_zod@4.3.6__express@5.2.1_hono@4.12.8_openap_a27fbefda71f01d718c4a26ef87624a2/node_modules/mppx/node_modules:/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/mppx@0.4.8_@modelcontextprotocol+sdk@1.27.1_zod@4.3.6__express@5.2.1_hono@4.12.8_openap_a27fbefda71f01d718c4a26ef87624a2/node_modules:/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/mppx@0.4.8_@modelcontextprotocol+sdk@1.27.1_zod@4.3.6__express@5.2.1_hono@4.12.8_openap_a27fbefda71f01d718c4a26ef87624a2/node_modules/mppx/src/node_modules:/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/mppx@0.4.8_@modelcontextprotocol+sdk@1.27.1_zod@4.3.6__express@5.2.1_hono@4.12.8_openap_a27fbefda71f01d718c4a26ef87624a2/node_modules/mppx/node_modules:/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/mppx@0.4.8_@modelcontextprotocol+sdk@1.27.1_zod@4.3.6__express@5.2.1_hono@4.12.8_openap_a27fbefda71f01d718c4a26ef87624a2/node_modules:/Users/projectxrp/Projects/mpp-examples/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../mppx/src/bin.ts" "$@"
else
  exec node  "$basedir/../mppx/src/bin.ts" "$@"
fi
